local MUTATION_MULT = {
	Gold = 20, Rainbow = 50, Shocked = 100, Frozen = 10,
	Wet = 2, Chilled = 2, Moonlit = 2, Bloodlit = 4,
	Electric = 2, Chained = 2, Starstruck = 2,
