function API.isPlayerInsidePlot(player, plot)
	if not (player and plot) then return false end
	local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not root then return false end
	local cf, size = plot:GetBoundingBox()
	local localPos = cf:PointToObjectSpace(root.Position)
	local half = size * 0.5
	return math.abs(localPos.X) <= half.X + 4 and math.abs(localPos.Z) <= half.Z + 4
end

