SNH.startPlantLoop = function()
	local lastPlantDebugAt = 0
	task.spawn(function()
		while running do
			if SNH.canPlantNow() and not plantWorkerRunning then
				plantWorkerRunning = true
				task.spawn(function()
					pcall(function()
						local _, plot = API.getLocalPlot()
						if not plot then return end
						if SNH.isPlantCapReached(plot) then
							if AUTO_PLANT_UPGRADE then
								SNH.tryUpgradeGardenPlant(false)
							else
								local now = tick()
								if now - lastPlantDebugAt >= 15 then
									lastPlantDebugAt = now
									print(("[So Nach Hup] Auto plant cap: %s"):format(SNH.debugPlantStatus(plot)))
								end
							end
							return
						end
						local work = SNH.buildPlantWorkQueue(plot)
						if #work == 0 then
							local now = tick()
							if now - lastPlantDebugAt >= 15 then
								lastPlantDebugAt = now
								print(("[So Nach Hup] Auto plant: %s"):format(SNH.debugPlantStatus(plot)))
							end
							return
						end
						-- Highest-price seed first; exhaust it, then next lower, and so on.
						for _, job in work do
							if not SNH.canPlantNow() then break end
							if SNH.isPlantCapReached(plot) then break end
							while SNH.canPlantNow() and not SNH.isPlantCapReached(plot) do
								if not SNH.hasSeedPlantWorkRemaining(plot, job.seedName) then break end
								local planted = SNH.plantBurst(false, job.seedName, PLANT_BURST_LIMIT)
								if planted <= 0 then break end
							end
						end
					end)
					plantWorkerRunning = false
				end)
			end
			task.wait(PLANT_GAP > 0 and PLANT_GAP or 0.1)
		end
	end)
end

